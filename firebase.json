{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/*.rules",
      "**/*.md",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|html)",
        "headers": [{"key": "Cache-Control", "value": "no-cache"}]
      },
      {
        "source": "**/*.@(png|jpg|svg|ico|woff2)",
        "headers": [{"key": "Cache-Control", "value": "max-age=604800"}]
      }
    ]
  }
}
